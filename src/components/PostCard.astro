---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';

const { post } = Astro.props;
const { data } = post;
const link = `/blog/${post.id}/`;
const FALLBACK_THUMBNAIL =
	'https://www.jobat.be//-/media/jobat/jobat-be/articles/kalender-2026.jpg?mw=890&hash=2DE5EA7BB922D5601411AC408E0FB2D9';
---

<article class="card">
	<a href={link} class="card__link" aria-label={`Read more: ${data.title}`}>
		{data.heroImage ? (
			<Image class="card__image" width={720} height={360} src={data.heroImage} alt="" />
		) : (
			<img class="card__image" src={FALLBACK_THUMBNAIL} alt="" loading="lazy" />
		)}
		<div class="card__body">
			<p class="card__date">
				<FormattedDate date={data.pubDate} />
			</p>
			<h3 class="card__title">{data.title}</h3>
			<p class="card__description">{data.description}</p>
		</div>
	</a>
</article>

<style>
	.card {
		background: var(--bg-primary);
		border-radius: 14px;
		box-shadow: 0 12px 30px rgba(var(--gray), 12%);
		transition: transform 0.15s ease, box-shadow 0.2s ease, background-color 0.3s ease;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		height: 400px;
	}

	.card__link {
		display: flex;
		flex-direction: column;
		height: 100%;
		color: inherit;
		text-decoration: none;
	}

	.card__image {
		display: block;
		width: 100%;
		height: 200px;
		flex-shrink: 0;
		object-fit: cover;
	}

	.card__body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		flex: 1;
		min-height: 0;
		overflow: hidden;
	}

	.card__date {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	.card__title {
		margin: 0;
		line-height: 1.25;
		font-size: 1.2rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card__description {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 1rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card:hover {
		transform: translateY(-3px);
		box-shadow: 0 16px 40px rgba(var(--gray), 18%);
	}
</style>

