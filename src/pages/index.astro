---
import { getCollection } from 'astro:content';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import PageLayout from '../layouts/PageLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts.slice(0, 3);
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<Hero
		eyebrow="Developer journal"
		title={`Hello, I'm ${SITE_AUTHOR}`}
		subtitle="Frontend engineer, builder and someone who documents what I learn when building real products."
		primaryCta={{ href: '/blog', label: 'Read blog' }}
		secondaryCta={{ href: '/about', label: 'About me' }}
	/>
</PageLayout>

<style>
	.section__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.section__link {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
	}
	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.4rem;
	}

	@media (max-width: 720px) {
		.section__header {
			flex-direction: column;
			align-items: flex-start;
		}
		.section__link {
			align-self: flex-start;
		}
	}
</style>
